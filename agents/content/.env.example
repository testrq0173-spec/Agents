# ────────────────────────────────────────────────────────────────────────────
# OpenClaw Content Department — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────
APP_NAME="OpenClaw Content Department"
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-64-char-string

# ── PostgreSQL ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://openclaw:password@localhost:5432/openclaw_content

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=your_redis_password   # uncomment if Redis requires a password

# ── Qdrant ─────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
# QDRANT_API_KEY=your_qdrant_cloud_key  # only needed for Qdrant Cloud

# ── Google Gemini (writing + briefing) ────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── OpenAI (embeddings + DALL-E 3 images) ─────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here   # <-- paste your rotated key here
EMBEDDING_MODEL=text-embedding-3-small
DALLE_MODEL=dall-e-3

# ── Cloudinary (image CDN) ─────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── WordPress CMS ──────────────────────────────────────────────────────────
WORDPRESS_SITE_URL=https://your-site.com
WORDPRESS_USERNAME=your_wp_username
WORDPRESS_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# ── Webflow CMS (optional) ─────────────────────────────────────────────────
# WEBFLOW_API_TOKEN=
# WEBFLOW_COLLECTION_ID=

# ── Trend Data APIs ────────────────────────────────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# AHREFS_API_KEY=

# ── Google APIs (Search Console + GA4) ─────────────────────────────────────
# GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account.json
GOOGLE_SEARCH_CONSOLE_SITE_URL=https://your-site.com

# ── Agent Timings (override defaults if needed) ────────────────────────────
AGENT01_CYCLE_HOURS=4.0
AGENT02_CYCLE_HOURS=2.0
AGENT03_CYCLE_DAYS=7.0
AGENT_HEARTBEAT_SECONDS=30.0
DEDUP_SIMILARITY_THRESHOLD=0.85
AUDIT_REWRITE_THRESHOLD=60.0
